'use client';

import React, { useState, useEffect, useRef } from 'react';
import { 
  Save, 
  Plus, 
  Trash2, 
  Image as ImageIcon, 
  Search, 
  X, 
  Check, 
  Loader2, 
  LayoutDashboard, 
  FileText, 
  Settings, 
  ChevronRight, 
  Eye, 
  Edit3, 
  Sparkles,
  ArrowLeft,
  Calendar,
  Tag,
  Share2,
  MoreVertical,
  AlertCircle,
  Clock,
  Zap,
  CheckCircle2,
  Type,
  Bold,
  Italic,
  List,
  Link as LinkIcon,
  Quote,
  Code,
  Heading1,
  Heading2,
  Heading3
} from 'lucide-react';
import Image from 'next/image';
import ReactMarkdown from 'react-markdown';
import remarkGfm from 'remark-gfm';
import remarkBreaks from 'remark-breaks';
import { GoogleGenAI } from "@google/genai";

interface SEOData {
  title: string;
  description: string;
  keywords: string;
}

interface CMSManagerProps {
  initialContent: any;
  onSave: (content: any) => Promise<void>;
}

interface SEOOptimizationResult {
  title: string;
  description: string;
  keywords: string;
  slug: string;
  imageAlt: string;
  faqs: { question: string; answer: string }[];
}

const CMSManager: React.FC<CMSManagerProps> = ({ initialContent, onSave }) => {
  const [localContent, setLocalContent] = useState(initialContent);
  const [activeSection, setActiveSection] = useState<'overview' | 'blog' | 'seo' | 'hero'>('overview');
  const [isSaving, setIsSaving] = useState(false);
  const [activePostIdx, setActivePostIdx] = useState<number | null>(null);
  const [showImagePicker, setShowImagePicker] = useState(false);
  const [unsplashQuery, setUnsplashQuery] = useState('');
  const [unsplashResults, setUnsplashResults] = useState<any[]>([]);
  const [isSearchingImages, setIsSearchingImages] = useState(false);
  const [isOptimizing, setIsOptimizing] = useState(false);
  const [showAIReview, setShowAIReview] = useState(false);
  const [aiReviewData, setAIReviewData] = useState<SEOOptimizationResult | null>(null);
  const [selectedAIFields, setSelectedAIFields] = useState<Record<string, boolean>>({
    title: true,
    description: true,
    keywords: true,
    slug: true,
    imageAlt: true,
    faqs: true
  });
  const [showDeleteConfirm, setShowDeleteConfirm] = useState(false);
  const [postToDeleteIdx, setPostToDeleteIdx] = useState<number | null>(null);
  const [editMode, setEditMode] = useState<'edit' | 'preview'>('edit');
  const [bulkSelection, setBulkSelection] = useState<number[]>([]);
  const [searchQuery, setSearchQuery] = useState('');
  const [filterCategory, setFilterCategory] = useState('all');

  const contentAreaRef = useRef<HTMLTextAreaElement>(null);

  // Sync local state with initial content if it changes externally
  useEffect(() => {
    setLocalContent(initialContent);
  }, [initialContent]);

  const handleSave = async () => {
    setIsSaving(true);
    try {
      await onSave(localContent);
    } catch (error) {
      console.error('Error saving CMS content:', error);
    } finally {
      setIsSaving(false);
    }
  };

  const handleBlogChange = (idx: number, field: string, value: any, isSEO = false) => {
    const updatedBlog = [...localContent.blog];
    if (isSEO) {
      updatedBlog[idx] = {
        ...updatedBlog[idx],
        seo: { ...updatedBlog[idx].seo, [field]: value }
      };
    } else {
      updatedBlog[idx] = { ...updatedBlog[idx], [field]: value };
    }
    setLocalContent({ ...localContent, blog: updatedBlog });
  };

  const addBlogPost = () => {
    const newPost = {
      id: Date.now().toString(),
      title: 'Nowy Artykuł',
      slug: 'nowy-artykul-' + Date.now().toString().slice(-4),
      excerpt: 'Krótki opis artykułu...',
      content: '# Nagłówek\n\nZacznij pisać tutaj...',
      image: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?q=80&w=2070',
      imageAlt: 'Biznes i prawo',
      category: 'Porady Prawne',
      publishedAt: new Date().toISOString().split('T')[0],
      author: 'Ekspert Vindicat',
      seo: {
        title: '',
        description: '',
        keywords: ''
      }
    };
    setLocalContent({ ...localContent, blog: [newPost, ...localContent.blog] });
    setActivePostIdx(0);
  };

  const confirmDeleteBlogPost = () => {
    if (postToDeleteIdx === null) return;
    const updatedBlog = localContent.blog.filter((_: any, i: number) => i !== postToDeleteIdx);
    setLocalContent({ ...localContent, blog: updatedBlog });
    setShowDeleteConfirm(false);
    setPostToDeleteIdx(null);
    if (activePostIdx === postToDeleteIdx) setActivePostIdx(null);
  };

  const searchUnsplash = async () => {
    if (!unsplashQuery && !unsplashResults.length) setUnsplashQuery('law business office');
    setIsSearchingImages(true);
    try {
      const response = await fetch(`https://api.unsplash.com/search/photos?query=${unsplashQuery || 'law business office'}&per_page=12&client_id=${process.env.NEXT_PUBLIC_UNSPLASH_ACCESS_KEY}`);
      const data = await response.json();
      setUnsplashResults(data.results || []);
    } catch (error) {
      console.error('Unsplash API error:', error);
    } finally {
      setIsSearchingImages(false);
    }
  };

  const selectUnsplashImage = (url: string) => {
    if (activePostIdx !== null) {
      handleBlogChange(activePostIdx, 'image', url);
      setShowImagePicker(false);
    }
  };

  const handleAIOptimize = async (idx: number) => {
    setIsOptimizing(true);
    const post = localContent.blog[idx];
    
    try {
      const ai = new GoogleGenAI({ apiKey: process.env.NEXT_PUBLIC_GEMINI_API_KEY! });
      const model = ai.models.generateContent({
        model: "gemini-3-flash-preview",
        contents: `Jesteś ekspertem SEO i copywriterem prawniczym. Zoptymalizuj poniższy artykuł pod kątem wyszukiwarek (Google). 
        Tytuł: ${post.title}
        Treść: ${post.content.substring(0, 2000)}
        
        Zwróć odpowiedź w formacie JSON:
        {
          "title": "Zoptymalizowany tytuł SEO (max 60 znaków)",
          "description": "Meta opis (max 160 znaków, zachęcający do kliknięcia)",
          "keywords": "słowa kluczowe po przecinku",
          "slug": "przyjazny-url-bez-polskich-znakow",
          "imageAlt": "opis zdjęcia dla SEO",
          "faqs": [{"question": "pytanie", "answer": "odpowiedź"}]
        }`
      });

      const response = await model;
      const result = JSON.parse(response.text.replace(/```json|```/g, ''));
      setAIReviewData(result);
      setShowAIReview(true);
    } catch (error) {
      console.error('AI Optimization error:', error);
    } finally {
      setIsOptimizing(false);
    }
  };

  const applyAIChanges = () => {
    if (activePostIdx === null || !aiReviewData) return;
    
    const updatedBlog = [...localContent.blog];
    const post = { ...updatedBlog[activePostIdx] };
    
    if (selectedAIFields.title) post.seo.title = aiReviewData.title;
    if (selectedAIFields.description) post.seo.description = aiReviewData.description;
    if (selectedAIFields.keywords) post.seo.keywords = aiReviewData.keywords;
    if (selectedAIFields.slug) post.slug = aiReviewData.slug;
    if (selectedAIFields.imageAlt) post.imageAlt = aiReviewData.imageAlt;
    
    updatedBlog[activePostIdx] = post;
    setLocalContent({ ...localContent, blog: updatedBlog });
    setShowAIReview(false);
  };

  const insertMarkdown = (type: string) => {
    if (!contentAreaRef.current) return;
    
    const textarea = contentAreaRef.current;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    const text = textarea.value;
    const selectedText = text.substring(start, end);
    
    let replacement = '';
    switch(type) {
      case 'bold': replacement = `**${selectedText || 'tekst'}**`; break;
      case 'italic': replacement = `*${selectedText || 'tekst'}*`; break;
      case 'h1': replacement = `\n# ${selectedText || 'Nagłówek 1'}\n`; break;
      case 'h2': replacement = `\n## ${selectedText || 'Nagłówek 2'}\n`; break;
      case 'h3': replacement = `\n### ${selectedText || 'Nagłówek 3'}\n`; break;
      case 'list': replacement = `\n- ${selectedText || 'element listy'}`; break;
      case 'quote': replacement = `\n> ${selectedText || 'cytat'}`; break;
      case 'link': replacement = `[${selectedText || 'tekst'}](https://)`; break;
      case 'code': replacement = `\`${selectedText || 'kod'}\``; break;
    }
    
    const newContent = text.substring(0, start) + replacement + text.substring(end);
    handleBlogChange(activePostIdx!, 'content', newContent);
    
    // Reset focus and selection
    setTimeout(() => {
      textarea.focus();
      textarea.setSelectionRange(start + replacement.length, start + replacement.length);
    }, 0);
  };

  const renderSEOPreview = (title: string, description: string) => (
    <div className="bg-white p-6 rounded-xl border border-slate-200 shadow-sm max-w-2xl">
      <div className="flex items-center gap-2 mb-1">
        <div className="w-6 h-6 bg-slate-100 rounded-full flex items-center justify-center">
          <span className="text-[10px] font-bold text-slate-400">G</span>
        </div>
        <span className="text-xs text-slate-500">vindicat.pl › blog › ...</span>
      </div>
      <h3 className="text-[#1a0dab] text-xl font-medium hover:underline cursor-pointer mb-1 truncate">
        {title || 'Tytuł artykułu pojawi się tutaj'}
      </h3>
      <p className="text-[#4d5156] text-sm line-clamp-2 leading-relaxed">
        {description || 'Opis SEO artykułu, który zachęci użytkowników do kliknięcia w wynikach wyszukiwania Google...'}
      </p>
    </div>
  );

  const filteredBlog = localContent.blog.filter((post: any) => {
    const matchesSearch = post.title.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesCategory = filterCategory === 'all' || post.category === filterCategory;
    return matchesSearch && matchesCategory;
  });

  return (
    <div className="flex flex-col h-full bg-[#020617] text-white">
      {/* Top Header */}
      <div className="flex items-center justify-between px-8 py-6 border-bottom border-slate-800 bg-[#020617]/80 backdrop-blur-md sticky top-0 z-50">
        <div className="flex items-center gap-4">
          <div className="w-12 h-12 bg-brand-blue rounded-2xl flex items-center justify-center text-white shadow-lg shadow-brand-blue/20">
            <LayoutDashboard size={24} />
          </div>
          <div>
            <h1 className="text-2xl font-black tracking-tight">System Zarządzania Treścią</h1>
            <p className="text-slate-500 text-sm font-medium">Centrum dowodzenia Twoją witryną</p>
          </div>
        </div>

        <div className="flex items-center gap-4">
          <div className="flex items-center gap-2 px-4 py-2 bg-slate-900 rounded-xl border border-slate-800">
            <div className="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
            <span className="text-xs font-black uppercase tracking-widest text-slate-400">Połączono: Live</span>
          </div>
          <button 
            onClick={handleSave}
            disabled={isSaving}
            className="flex items-center gap-3 px-8 py-4 bg-brand-blue text-white rounded-2xl font-black hover:bg-blue-600 transition-all shadow-xl shadow-brand-blue/20 disabled:opacity-50 group"
          >
            {isSaving ? <Loader2 size={20} className="animate-spin" /> : <Save size={20} className="group-hover:scale-110 transition-transform" />}
            Zapisz zmiany
          </button>
        </div>
      </div>

      <div className="flex flex-1 overflow-hidden">
        {/* Sidebar Navigation */}
        <div className="w-80 border-right border-slate-800 p-6 space-y-2 overflow-y-auto">
          <p className="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-4 px-4">Menu Główne</p>
          
          {[
            { id: 'overview', label: 'Przegląd', icon: LayoutDashboard, color: 'text-brand-blue' },
            { id: 'blog', label: 'Blog & Artykuły', icon: FileText, color: 'text-purple-500' },
            { id: 'hero', label: 'Sekcja Hero', icon: Zap, color: 'text-yellow-500' },
            { id: 'seo', label: 'Ustawienia SEO', icon: Settings, color: 'text-slate-400' },
          ].map((item) => (
            <button
              key={item.id}
              onClick={() => {
                setActiveSection(item.id as any);
                if (item.id !== 'blog') setActivePostIdx(null);
              }}
              className={`w-full flex items-center justify-between p-4 rounded-2xl transition-all group ${
                activeSection === item.id 
                ? 'bg-brand-blue/10 text-brand-blue border border-brand-blue/20' 
                : 'text-slate-400 hover:bg-slate-900 hover:text-white'
              }`}
            >
              <div className="flex items-center gap-4">
                <item.icon size={20} className={activeSection === item.id ? 'text-brand-blue' : 'text-slate-500 group-hover:text-white transition-colors'} />
                <span className="font-bold">{item.label}</span>
              </div>
              <ChevronRight size={16} className={`transition-transform ${activeSection === item.id ? 'rotate-90' : 'opacity-0 group-hover:opacity-100'}`} />
            </button>
          ))}

          <div className="pt-10">
            <p className="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-4 px-4">Statystyki</p>
            <div className="grid grid-cols-2 gap-3 px-2">
              <div className="bg-slate-900/50 p-4 rounded-2xl border border-slate-800">
                <p className="text-[10px] font-black text-slate-500 uppercase mb-1">Posty</p>
                <p className="text-xl font-black text-white">{localContent.blog.length}</p>
              </div>
              <div className="bg-slate-900/50 p-4 rounded-2xl border border-slate-800">
                <p className="text-[10px] font-black text-slate-500 uppercase mb-1">SEO Score</p>
                <p className="text-xl font-black text-brand-blue">94%</p>
              </div>
            </div>
          </div>
        </div>

        {/* Main Content Area */}
        <div className="flex-1 overflow-y-auto bg-[#020617] p-8 custom-scrollbar">
          {activeSection === 'overview' && (
            <div className="max-w-5xl mx-auto space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
              <div className="grid grid-cols-3 gap-6">
                <div className="col-span-2 bg-gradient-to-br from-brand-blue to-blue-700 p-10 rounded-[40px] shadow-2xl shadow-brand-blue/20 relative overflow-hidden group">
                  <div className="relative z-10">
                    <h2 className="text-4xl font-black text-white mb-4">Witaj w Vindicat CMS</h2>
                    <p className="text-blue-100 font-medium text-lg max-w-md mb-8">Zarządzaj treścią swojej kancelarii z łatwością. Dodawaj artykuły, optymalizuj SEO i buduj zaufanie klientów.</p>
                    <button 
                      onClick={() => setActiveSection('blog')}
                      className="px-8 py-4 bg-white text-brand-blue rounded-2xl font-black hover:scale-105 transition-transform shadow-xl"
                    >
                      Zacznij pisać
                    </button>
                  </div>
                  <Sparkles className="absolute top-10 right-10 text-white/20 animate-pulse" size={120} />
                </div>
                <div className="bg-slate-900 border border-slate-800 p-10 rounded-[40px] flex flex-col justify-center items-center text-center">
                  <div className="w-20 h-20 bg-brand-blue/10 rounded-3xl flex items-center justify-center text-brand-blue mb-6">
                    <Clock size={40} />
                  </div>
                  <h3 className="text-xl font-black text-white mb-2">Ostatnia edycja</h3>
                  <p className="text-slate-500 font-bold">Dzisiaj, 14:20</p>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-6">
                <div className="bg-slate-900 border border-slate-800 p-8 rounded-[40px] space-y-6">
                  <h3 className="text-xl font-black text-white flex items-center gap-3">
                    <FileText className="text-brand-blue" /> Ostatnie Artykuły
                  </h3>
                  <div className="space-y-4">
                    {localContent.blog.slice(0, 3).map((post: any, i: number) => (
                      <div key={i} className="flex items-center justify-between p-4 bg-slate-800/50 rounded-2xl border border-slate-700/50 group hover:border-brand-blue/50 transition-all">
                        <div className="flex items-center gap-4">
                          <div className="relative w-12 h-12 rounded-xl overflow-hidden">
                            <Image src={post.image} alt={post.title} fill className="object-cover" referrerPolicy="no-referrer" />
                          </div>
                          <div>
                            <p className="font-bold text-white group-hover:text-brand-blue transition-colors">{post.title}</p>
                            <p className="text-xs text-slate-500 font-medium">{post.publishedAt}</p>
                          </div>
                        </div>
                        <button onClick={() => { setActiveSection('blog'); setActivePostIdx(i); }} className="p-2 text-slate-500 hover:text-white transition-colors">
                          <Edit3 size={18} />
                        </button>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="bg-slate-900 border border-slate-800 p-8 rounded-[40px] space-y-6">
                  <h3 className="text-xl font-black text-white flex items-center gap-3">
                    <Zap className="text-yellow-500" /> Szybkie Akcje
                  </h3>
                  <div className="grid grid-cols-2 gap-4">
                    <button onClick={addBlogPost} className="p-6 bg-slate-800/50 rounded-3xl border border-slate-700/50 hover:border-brand-blue transition-all text-left group">
                      <Plus className="text-brand-blue mb-4 group-hover:scale-110 transition-transform" />
                      <p className="font-black text-white">Nowy Post</p>
                      <p className="text-xs text-slate-500 font-medium">Dodaj artykuł na bloga</p>
                    </button>
                    <button onClick={() => setActiveSection('seo')} className="p-6 bg-slate-800/50 rounded-3xl border border-slate-700/50 hover:border-brand-blue transition-all text-left group">
                      <Search className="text-purple-500 mb-4 group-hover:scale-110 transition-transform" />
                      <p className="font-black text-white">SEO Audit</p>
                      <p className="text-xs text-slate-500 font-medium">Sprawdź widoczność</p>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )}

          {activeSection === 'blog' && activePostIdx === null && (
            <div className="max-w-6xl mx-auto space-y-8 animate-in fade-in duration-500">
              <div className="flex items-center justify-between">
                <div>
                  <h2 className="text-3xl font-black text-white">Blog & Artykuły</h2>
                  <p className="text-slate-500 font-medium">Zarządzaj bazą wiedzy swojej kancelarii</p>
                </div>
                <button 
                  onClick={addBlogPost}
                  className="flex items-center gap-3 px-8 py-4 bg-brand-blue text-white rounded-2xl font-black hover:bg-blue-600 transition-all shadow-xl shadow-brand-blue/20"
                >
                  <Plus size={20} /> Nowy Artykuł
                </button>
              </div>

              {/* Filters & Search */}
              <div className="flex flex-wrap items-center gap-4 bg-slate-900/50 p-4 rounded-3xl border border-slate-800">
                <div className="relative flex-1 min-w-[300px]">
                  <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500" size={18} />
                  <input 
                    type="text" 
                    placeholder="Szukaj artykułów..."
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="w-full pl-12 pr-6 py-3 bg-slate-900 border border-slate-800 rounded-2xl text-white font-bold outline-none focus:border-brand-blue transition-all"
                  />
                </div>
                <select 
                  value={filterCategory}
                  onChange={(e) => setFilterCategory(e.target.value)}
                  className="px-6 py-3 bg-slate-900 border border-slate-800 rounded-2xl text-white font-bold outline-none focus:border-brand-blue transition-all appearance-none cursor-pointer"
                >
                  <option value="all">Wszystkie kategorie</option>
                  <option value="Porady Prawne">Porady Prawne</option>
                  <option value="Windykacja">Windykacja</option>
                  <option value="Case Study">Case Study</option>
                  <option value="Aktualności">Aktualności</option>
                </select>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {filteredBlog.map((post: any, idx: number) => (
                  <div 
                    key={post.id} 
                    className="bg-slate-900 border border-slate-800 rounded-[40px] overflow-hidden group hover:border-brand-blue transition-all flex flex-col h-full"
                  >
                    <div className="relative aspect-video">
                      <Image 
                        src={post.image} 
                        alt={post.title} 
                        fill 
                        className="object-cover group-hover:scale-105 transition-transform duration-700" 
                        referrerPolicy="no-referrer"
                      />
                      <div className="absolute top-4 left-4">
                        <span className="px-3 py-1 bg-brand-blue text-white text-[10px] font-black uppercase tracking-widest rounded-lg shadow-lg">
                          {post.category}
                        </span>
                      </div>
                      <div className="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-transparent to-transparent opacity-60"></div>
                    </div>
                    <div className="p-8 flex-1 flex flex-col">
                      <div className="flex items-center gap-3 text-slate-500 text-[10px] font-black uppercase tracking-widest mb-4">
                        <Calendar size={12} /> {post.publishedAt}
                        <span className="w-1 h-1 bg-slate-700 rounded-full"></span>
                        <Clock size={12} /> 5 min czytania
                      </div>
                      <h3 className="text-xl font-black text-white mb-4 line-clamp-2 group-hover:text-brand-blue transition-colors">
                        {post.title}
                      </h3>
                      <p className="text-slate-400 text-sm font-medium line-clamp-3 mb-8 flex-1">
                        {post.excerpt}
                      </p>
                      <div className="flex items-center justify-between pt-6 border-t border-slate-800">
                        <button 
                          onClick={() => setActivePostIdx(localContent.blog.indexOf(post))}
                          className="flex items-center gap-2 text-brand-blue font-black text-xs uppercase tracking-widest hover:gap-4 transition-all"
                        >
                          Edytuj <ChevronRight size={14} />
                        </button>
                        <button 
                          onClick={() => { setPostToDeleteIdx(localContent.blog.indexOf(post)); setShowDeleteConfirm(true); }}
                          className="p-2 text-slate-600 hover:text-red-500 transition-colors"
                        >
                          <Trash2 size={18} />
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {activeSection === 'blog' && activePostIdx !== null && (
            <div className="max-w-6xl mx-auto space-y-8 animate-in slide-in-from-right-8 duration-500">
              {(() => {
                const post = localContent.blog[activePostIdx];
                const idx = activePostIdx;
                
                return (
                  <>
                    <div className="flex items-center justify-between">
                      <button 
                        onClick={() => setActivePostIdx(null)}
                        className="flex items-center gap-2 text-slate-500 hover:text-white font-black text-xs uppercase tracking-widest transition-all"
                      >
                        <ArrowLeft size={16} /> Powrót do listy
                      </button>
                      <div className="flex items-center gap-4">
                        <div className="flex bg-slate-900 p-1 rounded-xl border border-slate-800">
                          <button 
                            onClick={() => setEditMode('edit')}
                            className={`px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all ${editMode === 'edit' ? 'bg-brand-blue text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}
                          >
                            Edytor
                          </button>
                          <button 
                            onClick={() => setEditMode('preview')}
                            className={`px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all ${editMode === 'preview' ? 'bg-brand-blue text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}
                          >
                            Podgląd
                          </button>
                        </div>
                        <button 
                          onClick={handleSave}
                          className="px-6 py-3 bg-brand-blue text-white rounded-xl font-black text-xs uppercase tracking-widest hover:bg-blue-600 transition-all shadow-lg shadow-brand-blue/20"
                        >
                          Zapisz artykuł
                        </button>
                      </div>
                    </div>

                    <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                      <div className="lg:col-span-2 space-y-8">
                        {editMode === 'edit' ? (
                          <div className="space-y-4">
                            <div className="flex items-center gap-2 p-2 bg-slate-900 border border-slate-800 rounded-2xl overflow-x-auto no-scrollbar">
                              <button onClick={() => insertMarkdown('h1')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Nagłówek 1"><Heading1 size={18} /></button>
                              <button onClick={() => insertMarkdown('h2')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Nagłówek 2"><Heading2 size={18} /></button>
                              <button onClick={() => insertMarkdown('h3')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Nagłówek 3"><Heading3 size={18} /></button>
                              <div className="w-px h-6 bg-slate-800 mx-1"></div>
                              <button onClick={() => insertMarkdown('bold')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Pogrubienie"><Bold size={18} /></button>
                              <button onClick={() => insertMarkdown('italic')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Kursywa"><Italic size={18} /></button>
                              <div className="w-px h-6 bg-slate-800 mx-1"></div>
                              <button onClick={() => insertMarkdown('list')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Lista"><List size={18} /></button>
                              <button onClick={() => insertMarkdown('quote')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Cytat"><Quote size={18} /></button>
                              <button onClick={() => insertMarkdown('link')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Link"><LinkIcon size={18} /></button>
                              <button onClick={() => insertMarkdown('code')} className="p-2 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all" title="Kod"><Code size={18} /></button>
                            </div>
                            <textarea 
                              ref={contentAreaRef}
                              rows={25}
                              value={post.content}
                              onChange={(e) => handleBlogChange(idx, 'content', e.target.value)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-3xl p-8 text-slate-300 font-mono text-sm focus:border-brand-blue outline-none transition-all resize-none custom-scrollbar"
                              placeholder="Treść artykułu (Markdown)..."
                            />
                          </div>
                        ) : (
                          <div className="w-full bg-white rounded-xl px-8 py-8 text-brand-navy overflow-y-auto max-h-[500px] prose prose-slate prose-sm lg:prose-base max-w-none">
                            <ReactMarkdown remarkPlugins={[remarkGfm, remarkBreaks]}>
                              {post.content}
                            </ReactMarkdown>
                          </div>
                        )}

                        <div className="space-y-2">
                          <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Tytuł Artykułu</label>
                          <input 
                            type="text" 
                            value={post.title}
                            onChange={(e) => {
                              handleBlogChange(idx, 'title', e.target.value);
                              // Auto-generate slug if it's a new post or empty
                              if (!post.slug) {
                                const slug = e.target.value.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
                                handleBlogChange(idx, 'slug', slug);
                              }
                            }}
                            className="w-full bg-slate-900 border border-slate-800 rounded-xl px-6 py-4 text-white font-bold focus:border-brand-blue outline-none transition-all"
                          />
                        </div>
                        <div className="space-y-2">
                          <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Slug (Przyjazny URL)</label>
                          <div className="flex items-center gap-2">
                            <span className="text-slate-500 text-xs font-bold">/blog/</span>
                            <input 
                              type="text" 
                              value={post.slug || ''}
                              onChange={(e) => handleBlogChange(idx, 'slug', e.target.value.toLowerCase().replace(/ /g, '-'))}
                              className="flex-1 bg-slate-900 border border-slate-800 rounded-xl px-6 py-4 text-white font-bold focus:border-brand-blue outline-none transition-all"
                            />
                          </div>
                        </div>
                        <div className="grid grid-cols-2 gap-4">
                          <div className="space-y-2">
                            <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Kategoria</label>
                            <select 
                              value={post.category}
                              onChange={(e) => handleBlogChange(idx, 'category', e.target.value)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-xl px-6 py-4 text-white font-bold focus:border-brand-blue outline-none transition-all appearance-none"
                            >
                              <option value="Porady Prawne">Porady Prawne</option>
                              <option value="Windykacja">Windykacja</option>
                              <option value="Case Study">Case Study</option>
                              <option value="Aktualności">Aktualności</option>
                            </select>
                          </div>
                          <div className="space-y-2">
                            <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Data Publikacji</label>
                            <input 
                              type="date" 
                              value={post.publishedAt || ''}
                              onChange={(e) => handleBlogChange(idx, 'publishedAt', e.target.value)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-xl px-6 py-4 text-white font-bold focus:border-brand-blue outline-none transition-all"
                            />
                          </div>
                        </div>
                        <div className="space-y-2">
                          <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Krótki Opis (Excerpt)</label>
                          <textarea 
                            rows={3}
                            value={post.excerpt}
                            onChange={(e) => handleBlogChange(idx, 'excerpt', e.target.value)}
                            className="w-full bg-slate-900 border border-slate-800 rounded-xl px-6 py-4 text-white font-medium focus:border-brand-blue outline-none transition-all"
                          />
                        </div>
                      </div>

                      <div className="space-y-8">
                        <div className="bg-slate-900/50 p-8 rounded-3xl border border-slate-800 space-y-6">
                          <div className="flex items-center justify-between">
                            <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                              <Search size={14} /> Optymalizacja SEO Wpisu
                            </h4>
                            <button 
                              onClick={() => handleAIOptimize(idx)}
                              disabled={isOptimizing}
                              className="flex items-center gap-2 px-3 py-1.5 bg-brand-blue/10 text-brand-blue border border-brand-blue/20 rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue hover:text-white transition-all disabled:opacity-50"
                            >
                              {isOptimizing ? <Loader2 size={12} className="animate-spin" /> : <Sparkles size={12} />}
                              AI SEO Assistant
                            </button>
                          </div>
                          <div className="space-y-2">
                            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest">SEO Tytuł</label>
                            <input 
                              type="text" 
                              value={post.seo?.title || ''}
                              onChange={(e) => handleBlogChange(idx, 'title', e.target.value, true)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white text-sm font-bold focus:border-brand-blue outline-none transition-all"
                            />
                          </div>
                          <div className="space-y-2">
                            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest">SEO Opis</label>
                            <textarea 
                              rows={3}
                              value={post.seo?.description || ''}
                              onChange={(e) => handleBlogChange(idx, 'description', e.target.value, true)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white text-sm font-medium focus:border-brand-blue outline-none transition-all"
                            />
                          </div>
                          <div className="space-y-2">
                            <label className="text-[10px] font-black text-slate-500 uppercase tracking-widest">Tekst Alternatywny Zdjęcia (ALT)</label>
                            <input 
                              type="text" 
                              value={post.imageAlt || ''}
                              onChange={(e) => handleBlogChange(idx, 'imageAlt', e.target.value)}
                              className="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white text-sm font-medium focus:border-brand-blue outline-none transition-all"
                            />
                            <p className="text-[9px] text-slate-500 font-bold">Opisz co jest na zdjęciu dla Google Grafika i czytników ekranu.</p>
                          </div>
                        </div>

                        <div className="space-y-4">
                          <label className="text-xs font-black text-slate-500 uppercase tracking-widest">Zdjęcie Wyróżniające</label>
                          <div className="relative group rounded-3xl overflow-hidden border border-slate-800 h-48">
                            <Image 
                              src={post.image} 
                              alt="Preview" 
                              fill
                              className="object-cover" 
                              referrerPolicy="no-referrer"
                            />
                            <div className="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
                              <button 
                                onClick={() => {
                                  setActivePostIdx(idx);
                                  setShowImagePicker(true);
                                  searchUnsplash();
                                }}
                                className="px-4 py-2 bg-brand-blue text-white rounded-xl font-bold text-xs flex items-center gap-2 hover:scale-105 transition-transform"
                              >
                                <ImageIcon size={14} /> Zmień zdjęcie (Unsplash)
                              </button>
                            </div>
                          </div>
                          <input 
                            type="text" 
                            value={post.image}
                            onChange={(e) => handleBlogChange(idx, 'image', e.target.value)}
                            placeholder="Lub wklej URL zdjęcia..."
                            className="w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white text-xs font-medium focus:border-brand-blue outline-none transition-all"
                          />
                        </div>

                        <div className="space-y-4">
                          <h4 className="text-xs font-black text-slate-500 uppercase tracking-widest">Podgląd w Google</h4>
                          {renderSEOPreview(post.seo?.title || post.title, post.seo?.description || post.excerpt)}
                        </div>
                      </div>
                    </div>
                  </>
                );
              })()}
            </div>
          )}
        </div>
      </div>

      {/* Unsplash Image Picker Modal */}
      {showImagePicker && (
        <div className="fixed inset-0 z-[110] flex items-center justify-center p-6">
          <div className="absolute inset-0 bg-[#020617]/90 backdrop-blur-md" onClick={() => setShowImagePicker(false)} />
          <div className="relative w-full max-w-4xl bg-[#0f172a] border border-slate-800 rounded-[40px] p-10 shadow-2xl animate-in zoom-in duration-300 max-h-[90vh] flex flex-col">
            <div className="flex justify-between items-center mb-8">
              <h2 className="text-2xl font-black text-white flex items-center gap-3">
                <ImageIcon size={28} className="text-brand-blue" /> Biblioteka Mediów (Unsplash)
              </h2>
              <button onClick={() => setShowImagePicker(false)} className="p-2 text-slate-500 hover:text-white transition-colors">
                <X size={24} />
              </button>
            </div>

            <div className="flex gap-4 mb-8">
              <div className="relative flex-1">
                <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500" size={18} />
                <input 
                  type="text" 
                  value={unsplashQuery}
                  onChange={(e) => setUnsplashQuery(e.target.value)}
                  onKeyDown={(e) => e.key === 'Enter' && searchUnsplash()}
                  placeholder="Szukaj profesjonalnych zdjęć biznesowych..."
                  className="w-full pl-12 pr-6 py-4 bg-slate-900 border border-slate-800 rounded-2xl text-white font-bold outline-none focus:border-brand-blue transition-all"
                />
              </div>
              <button 
                onClick={searchUnsplash}
                disabled={isSearchingImages}
                className="px-8 py-4 bg-brand-blue text-white rounded-2xl font-black flex items-center gap-2 hover:bg-blue-600 transition-all"
              >
                {isSearchingImages ? <Loader2 size={20} className="animate-spin" /> : <Search size={20} />}
                Szukaj
              </button>
            </div>

            <div className="overflow-y-auto flex-1 pr-2 custom-scrollbar">
              {unsplashResults.length > 0 ? (
                <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                  {unsplashResults.map((img) => (
                    <div 
                      key={img.id} 
                      onClick={() => selectUnsplashImage(img.urls.regular)}
                      className="relative aspect-video group cursor-pointer rounded-2xl overflow-hidden border border-slate-800 hover:border-brand-blue transition-all"
                    >
                      <Image 
                        src={img.urls.small} 
                        alt={img.alt_description || "Unsplash image"} 
                        fill
                        className="object-cover group-hover:scale-110 transition-transform duration-500" 
                        referrerPolicy="no-referrer"
                      />
                      <div className="absolute inset-0 bg-brand-blue/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <span className="bg-brand-blue text-white px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest">Wybierz</span>
                      </div>
                      <div className="absolute bottom-0 left-0 right-0 p-2 bg-gradient-to-t from-black/80 to-transparent">
                        <p className="text-[8px] text-white/60 truncate">Autor: {img.user.name}</p>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="h-full flex flex-col items-center justify-center text-slate-600 py-20">
                  <ImageIcon size={48} className="mb-4 opacity-20" />
                  <p className="font-bold">Wpisz frazę i naciśnij Enter, aby wyszukać zdjęcia.</p>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {/* AI SEO Review Modal */}
      {showAIReview && aiReviewData && activePostIdx !== null && (
        <div className="fixed inset-0 z-[120] flex items-center justify-center p-6">
          <div className="absolute inset-0 bg-[#020617]/95 backdrop-blur-xl" onClick={() => setShowAIReview(false)} />
          <div className="relative w-full max-w-5xl bg-[#0f172a] border border-slate-800 rounded-[40px] p-10 shadow-2xl animate-in zoom-in duration-300 max-h-[90vh] flex flex-col">
            <div className="flex justify-between items-center mb-8">
              <div className="flex items-center gap-4">
                <div className="w-12 h-12 bg-brand-blue rounded-2xl flex items-center justify-center text-white shadow-lg shadow-brand-blue/20">
                  <Sparkles size={24} />
                </div>
                <div>
                  <h2 className="text-2xl font-black text-white">AI SEO Assistant: Weryfikacja</h2>
                  <p className="text-slate-500 text-sm font-medium">Przejrzyj i wybierz elementy do wdrożenia.</p>
                </div>
              </div>
              <button onClick={() => setShowAIReview(false)} className="p-2 text-slate-500 hover:text-white transition-colors">
                <X size={24} />
              </button>
            </div>

            <div className="overflow-y-auto flex-1 pr-4 custom-scrollbar space-y-6">
              {[
                { id: 'title', label: 'SEO Tytuł', current: localContent.blog[activePostIdx].seo.title, suggested: aiReviewData.title },
                { id: 'description', label: 'SEO Opis', current: localContent.blog[activePostIdx].seo.description, suggested: aiReviewData.description },
                { id: 'keywords', label: 'Słowa Kluczowe', current: localContent.blog[activePostIdx].seo.keywords, suggested: aiReviewData.keywords },
                { id: 'slug', label: 'Slug (URL)', current: localContent.blog[activePostIdx].slug, suggested: aiReviewData.slug },
                { id: 'imageAlt', label: 'Tekst ALT Zdjęcia', current: localContent.blog[activePostIdx].imageAlt, suggested: aiReviewData.imageAlt },
              ].map((field) => (
                <div key={field.id} className="bg-slate-900/50 border border-slate-800 rounded-3xl p-6 hover:border-slate-700 transition-all">
                  <div className="flex items-center justify-between mb-4">
                    <label className="text-xs font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
                      <div className={`w-2 h-2 rounded-full ${selectedAIFields[field.id] ? 'bg-brand-blue' : 'bg-slate-700'}`}></div>
                      {field.label}
                    </label>
                    <button 
                      onClick={() => setSelectedAIFields(prev => ({ ...prev, [field.id]: !prev[field.id] }))}
                      className={`px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${
                        selectedAIFields[field.id] 
                        ? 'bg-brand-blue text-white' 
                        : 'bg-slate-800 text-slate-500 hover:text-slate-300'
                      }`}
                    >
                      {selectedAIFields[field.id] ? 'Zaakceptowano' : 'Odrzucono'}
                    </button>
                  </div>
                  <div className="grid md:grid-cols-2 gap-6">
                    <div className="space-y-2">
                      <p className="text-[10px] font-black text-slate-600 uppercase tracking-tighter">Obecnie:</p>
                      <p className="text-sm text-slate-400 font-medium italic">{field.current || '(Brak)'}</p>
                    </div>
                    <div className="space-y-2">
                      <p className="text-[10px] font-black text-brand-blue uppercase tracking-tighter">Sugestia AI:</p>
                      <p className="text-sm text-white font-bold">{field.suggested}</p>
                    </div>
                  </div>
                </div>
              ))}

              {/* FAQ Section in Review */}
              <div className="bg-slate-900/50 border border-slate-800 rounded-3xl p-6 hover:border-slate-700 transition-all">
                <div className="flex items-center justify-between mb-4">
                  <label className="text-xs font-black text-slate-500 uppercase tracking-widest flex items-center gap-2">
                    <div className={`w-2 h-2 rounded-full ${selectedAIFields.faqs ? 'bg-brand-blue' : 'bg-slate-700'}`}></div>
                    Sekcja FAQ (Pytania i Odpowiedzi)
                  </label>
                  <button 
                    onClick={() => setSelectedAIFields(prev => ({ ...prev, faqs: !prev.faqs }))}
                    className={`px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${
                      selectedAIFields.faqs 
                      ? 'bg-brand-blue text-white' 
                      : 'bg-slate-800 text-slate-500 hover:text-slate-300'
                    }`}
                  >
                    {selectedAIFields.faqs ? 'Zaakceptowano' : 'Odrzucono'}
                  </button>
                </div>
                <div className="space-y-4">
                  {aiReviewData.faqs.map((faq, fidx) => (
                    <div key={fidx} className="p-4 bg-slate-900 rounded-2xl border border-slate-800">
                      <p className="text-sm font-black text-white mb-1">{faq.question}</p>
                      <p className="text-xs text-slate-400 font-medium">{faq.answer}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div className="mt-10 flex gap-4">
              <button 
                onClick={() => setShowAIReview(false)}
                className="flex-1 px-8 py-4 bg-slate-800 text-slate-400 rounded-2xl font-black hover:bg-slate-700 transition-all"
              >
                Anuluj wszystko
              </button>
              <button 
                onClick={applyAIChanges}
                className="flex-[2] px-8 py-4 bg-brand-blue text-white rounded-2xl font-black hover:bg-blue-600 transition-all shadow-xl shadow-brand-blue/20 flex items-center justify-center gap-3"
              >
                <Check size={20} /> Wdróż wybrane zmiany
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Delete Confirmation Modal */}
      {showDeleteConfirm && postToDeleteIdx !== null && (
        <div className="fixed inset-0 z-[130] flex items-center justify-center p-6">
          <div className="absolute inset-0 bg-[#020617]/90 backdrop-blur-md" onClick={() => setShowDeleteConfirm(false)} />
          <div className="relative w-full max-w-md bg-[#0f172a] border border-slate-800 rounded-[40px] p-10 shadow-2xl animate-in zoom-in duration-300">
            <div className="flex flex-col items-center text-center">
              <div className="w-20 h-20 bg-red-500/10 text-red-500 rounded-3xl flex items-center justify-center mb-6 shadow-lg shadow-red-500/10">
                <Trash2 size={40} />
              </div>
              <h2 className="text-2xl font-black text-white mb-4">Usuwanie Artykułu</h2>
              <p className="text-slate-400 font-medium mb-8">
                Czy na pewno chcesz usunąć artykuł <span className="text-white font-bold">"{localContent.blog[postToDeleteIdx]?.title}"</span>? Tej operacji nie można cofnąć.
              </p>
              <div className="flex gap-4 w-full">
                <button 
                  onClick={() => setShowDeleteConfirm(false)}
                  className="flex-1 px-6 py-4 bg-slate-800 text-slate-400 rounded-2xl font-black hover:bg-slate-700 transition-all"
                >
                  Anuluj
                </button>
                <button 
                  onClick={confirmDeleteBlogPost}
                  className="flex-1 px-6 py-4 bg-red-500 text-white rounded-2xl font-black hover:bg-red-600 transition-all shadow-xl shadow-red-500/20"
                >
                  Usuń trwale
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default CMSManager;
